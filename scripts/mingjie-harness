#!/usr/bin/env python3
"""Project-scope Harness state and evidence CLI for Mingjie Stack."""
from __future__ import annotations

import argparse
from datetime import datetime
from pathlib import Path
import re
import shutil
import subprocess
import sys


HARNESS_DIR = Path("docs") / "mingjie-stack"
LEGACY_DIR = Path(".mingjie")
STANDARD_RUN_FILES = [
    "INTAKE.md",
    "PLAN.md",
    "GUARD.md",
    "EVIDENCE.md",
    "REVIEW.md",
    "VERIFY.md",
    "ACCEPT.md",
    "LESSONS.md",
]
GITIGNORE_MARKER = "# Mingjie Stack runtime state"
GITIGNORE_ENTRIES = [
    "docs/mingjie-stack/STATE.md",
    "docs/mingjie-stack/runs/",
]
PINNED_FILE = "PINNED"
BRIDGE = Path(__file__).resolve().parent / "mingjie-bridge"
MULTI_AGENT_ROLES = [
    {
        "slug": "conservative",
        "file": "draft-conservative.md",
        "role": "Conservative Planner",
        "recipient": "claude",
        "focus": "minimal risk, reversible changes, small steps, proven patterns",
    },
    {
        "slug": "aggressive",
        "file": "draft-aggressive.md",
        "role": "Aggressive Planner",
        "recipient": "codex",
        "focus": "higher-leverage automation, bolder architecture options, under-scoping challenges",
    },
    {
        "slug": "pragmatic",
        "file": "draft-pragmatic.md",
        "role": "Pragmatic Planner",
        "recipient": "claude",
        "focus": "fastest reliable path, dependency order, practical verification",
    },
    {
        "slug": "skeptic-guard",
        "file": "draft-skeptic-guard.md",
        "role": "Skeptic-Guard",
        "recipient": "codex",
        "focus": "hard stops, org/security/git/workflow risks, unsafe parallelism, missing verification",
    },
]


def now() -> str:
    return datetime.now().astimezone().isoformat(timespec="seconds")


def default_run_id() -> str:
    return datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")


def harness_dir(root: Path) -> Path:
    return root / HARNESS_DIR


def legacy_dir(root: Path) -> Path:
    return root / LEGACY_DIR


def write_if_missing(path: Path, content: str) -> bool:
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    return True


def ensure_gitignore(root: Path) -> bool:
    path = root / ".gitignore"
    existing = path.read_text(encoding="utf-8") if path.exists() else ""
    missing = [entry for entry in GITIGNORE_ENTRIES if entry not in existing.splitlines()]
    if not missing:
        return False

    addition = "\n".join([GITIGNORE_MARKER, *missing, ""])
    if existing and not existing.endswith("\n"):
        existing += "\n"
    path.write_text(existing + addition, encoding="utf-8")
    return True


def ensure_harness(root: Path) -> Path:
    base = harness_dir(root)
    base.mkdir(parents=True, exist_ok=True)
    write_if_missing(
        base / "PROJECT.md",
        "# Mingjie Project\n\nRecord project-specific run, test, build, and ship facts here.\n",
    )
    write_if_missing(
        base / "RUNBOOK.md",
        "# Mingjie Runbook\n\nRecord repeatable project operations here.\n",
    )
    write_if_missing(
        base / "lessons.md",
        "# Mingjie Project Lessons\n\nProject-scope lessons only. Do not record secrets.\n",
    )
    return base


def run_dir(root: Path, run_id: str) -> Path:
    return harness_dir(root) / "runs" / run_id


def runs_dir(root: Path) -> Path:
    return harness_dir(root) / "runs"


def write_state(
    root: Path,
    *,
    run_id: str | None,
    current_stage: str,
    next_stage: str,
    blocker: str,
) -> Path:
    base = ensure_harness(root)
    state = base / "STATE.md"
    lines = [
        "# Mingjie State",
        "",
        f"- run_id: {run_id or 'none'}",
        f"- current_stage: {current_stage}",
        f"- next_stage: {next_stage}",
        f"- blocker: {blocker}",
        f"- updated_at: {now()}",
        "",
    ]
    state.write_text("\n".join(lines), encoding="utf-8")
    return state


def create_run(root: Path, run_id: str) -> Path:
    directory = run_dir(root, run_id)
    directory.mkdir(parents=True, exist_ok=True)
    for name in STANDARD_RUN_FILES:
        write_if_missing(directory / name, f"# {name.removesuffix('.md').title()}\n\n")
    return directory


def multi_agent_dir(root: Path, run_id: str) -> Path:
    return run_dir(root, run_id) / "multi-agent"


def multi_agent_brief(goal: str, context: str, constraints: str, files: str) -> str:
    return "\n".join(
        [
            "# Multi-Agent Planning Brief",
            "",
            "Goal:",
            goal or "TBD",
            "",
            "Context:",
            context or "TBD",
            "",
            "Constraints:",
            constraints or "Use Mingjie Stack Guard policy. Draft agents are advisory/read-only by default.",
            "",
            "Files:",
            files or "TBD",
            "",
            "Requested action:",
            "Draft a plan from the assigned role. Do not edit files.",
            "",
            "Expected output:",
            "Recommended approach, task breakdown, risks and hard stops, verification plan, what another plan may miss, confidence level.",
            "",
        ]
    )


def role_prompt(brief_path: Path, role: dict[str, str]) -> str:
    return "\n".join(
        [
            f"# {role['role']}",
            "",
            f"Brief: `{brief_path.name}`",
            f"Focus: {role['focus']}",
            "",
            "Rules:",
            "- Advisory/read-only. Do not edit files.",
            "- Use the shared brief as the source of truth.",
            "- Surface tradeoffs and hard stops explicitly.",
            "",
            "Recommended approach:",
            "",
            "Task breakdown:",
            "",
            "Risks and hard stops:",
            "",
            "Verification plan:",
            "",
            "What another plan may miss:",
            "",
            "Confidence level:",
            "",
        ]
    )


def skeleton_file(title: str, body: list[str]) -> str:
    return "\n".join([f"# {title}", "", *body, ""])


def create_multi_agent_artifacts(
    root: Path,
    *,
    run_id: str,
    goal: str,
    context: str,
    constraints: str,
    files: str,
) -> Path:
    create_run(root, run_id)
    directory = multi_agent_dir(root, run_id)
    directory.mkdir(parents=True, exist_ok=True)
    brief = directory / "BRIEF.md"
    write_if_missing(brief, multi_agent_brief(goal, context, constraints, files))
    for role in MULTI_AGENT_ROLES:
        write_if_missing(directory / role["file"], role_prompt(brief, role))
    write_if_missing(
        directory / "synthesis.md",
        skeleton_file(
            "Multi-Agent Synthesis",
            [
                "Agreements:",
                "",
                "Conflicts:",
                "",
                "Adopted ideas:",
                "",
                "Rejected ideas:",
                "",
                "Recommended direction:",
                "",
            ],
        ),
    )
    write_if_missing(
        directory / "final-plan.md",
        skeleton_file(
            "Judge Final Plan",
            [
                "Final direction:",
                "",
                "Tasks:",
                "",
                "Parallelization and ownership:",
                "",
                "Verification:",
                "",
                "Guard requirements:",
                "",
            ],
        ),
    )
    return directory


def draft_is_ready(path: Path) -> bool:
    if not path.exists():
        return False
    text = path.read_text(encoding="utf-8")
    placeholders = [
        "Recommended approach:\n\nTask breakdown:",
        "Recommended approach:\r\n\r\nTask breakdown:",
    ]
    return not any(placeholder in text for placeholder in placeholders)


def skeleton_status(path: Path) -> str:
    if not path.exists():
        return "missing"
    text = path.read_text(encoding="utf-8")
    return "skeleton" if "Final direction:\n\nTasks:" in text or "Agreements:\n\nConflicts:" in text else "ready"


def run_directories(root: Path) -> list[Path]:
    directory = runs_dir(root)
    if not directory.exists():
        return []
    return sorted(
        [
            path
            for path in directory.iterdir()
            if path.is_dir() and path.name != "archive"
        ],
        key=lambda path: path.name,
    )


def is_pinned(directory: Path) -> bool:
    return (directory / PINNED_FILE).exists()


def month_for_run(run_id: str) -> str:
    match = re.match(r"^(\d{4})(\d{2})", run_id)
    if match:
        return f"{match.group(1)}-{match.group(2)}"
    return datetime.now().astimezone().strftime("%Y-%m")


def first_nonempty_line(path: Path) -> str:
    if not path.exists():
        return ""
    for line in path.read_text(encoding="utf-8").splitlines():
        text = line.strip()
        if text and not text.startswith("#"):
            return text
    return ""


def run_summary(directory: Path) -> str:
    run_id = directory.name
    evidence = directory / "EVIDENCE.md"
    accept = first_nonempty_line(directory / "ACCEPT.md")
    verify = first_nonempty_line(directory / "VERIFY.md")
    evidence_lines = []
    if evidence.exists():
        for line in evidence.read_text(encoding="utf-8").splitlines():
            text = line.strip()
            if text.startswith("- Command:") or text.startswith("- Result:"):
                evidence_lines.append(text)

    lines = [
        f"## {run_id}",
        "",
        f"- Run: `{run_id}`",
        f"- Pinned: {'yes' if is_pinned(directory) else 'no'}",
    ]
    if accept:
        lines.append(f"- Accept: {accept}")
    if verify:
        lines.append(f"- Verify: {verify}")
    lines.extend(evidence_lines or ["- Evidence: none recorded"])
    lines.append("")
    return "\n".join(lines)


def append_unique(path: Path, block: str, marker: str) -> bool:
    existing = path.read_text(encoding="utf-8") if path.exists() else ""
    if marker in existing:
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    if existing and not existing.endswith("\n"):
        existing += "\n"
    path.write_text(existing + block + "\n", encoding="utf-8")
    return True


def summarize_run(root: Path, run_id: str) -> bool:
    directory = run_dir(root, run_id)
    if not directory.exists():
        raise SystemExit(f"run not found: {run_id}")
    base = ensure_harness(root)
    block = run_summary(directory)
    index_block = f"- `{run_id}`: summarized in `runs/archive/{month_for_run(run_id)}.md`\n"
    changed_index = append_unique(base / "RUNS_INDEX.md", index_block, f"`{run_id}`")
    changed_archive = append_unique(
        runs_dir(root) / "archive" / f"{month_for_run(run_id)}.md",
        block,
        f"## {run_id}",
    )
    return changed_index or changed_archive


def command_init(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    base = ensure_harness(root)
    changed_gitignore = ensure_gitignore(root)
    print(f"Initialized Harness at {base.relative_to(root)}")
    if changed_gitignore:
        print("Updated .gitignore for volatile Harness state")
    return 0


def command_start_run(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    run_id = args.id or default_run_id()
    directory = create_run(root, run_id)
    write_state(root, run_id=run_id, current_stage=args.stage, next_stage=args.next, blocker="none")
    print(f"Started run {run_id} at {directory.relative_to(root)}")
    return 0


def command_update_state(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    state = write_state(
        root,
        run_id=args.run_id,
        current_stage=args.stage,
        next_stage=args.next,
        blocker=args.blocker,
    )
    print(f"Updated {state.relative_to(root)}")
    return 0


def command_append_evidence(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    run_id = args.run_id or default_run_id()
    directory = create_run(root, run_id)
    evidence = directory / "EVIDENCE.md"
    with evidence.open("a", encoding="utf-8") as fh:
        fh.write(f"\n## {args.title}\n\n")
        fh.write(f"- Time: {now()}\n")
        if args.command:
            fh.write(f"- Command: `{args.command}`\n")
        fh.write(f"- Result: {args.result}\n")
        if args.note:
            fh.write(f"- Note: {args.note}\n")
    print(f"Appended evidence to {evidence.relative_to(root)}")
    return 0


def find_state(root: Path) -> tuple[str, Path | None]:
    current = harness_dir(root) / "STATE.md"
    if current.exists():
        return "current", current
    legacy = legacy_dir(root) / "STATE.md"
    if legacy.exists():
        return "legacy", legacy
    return "missing", None


def command_status(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    base = harness_dir(root)
    source, state = find_state(root)
    print(f"Harness path: {base.relative_to(root)}")
    print(f"State source: {source}")
    if state is None:
        print("State file: none")
        return 0

    print(f"State file: {state.relative_to(root)}")
    text = state.read_text(encoding="utf-8").strip()
    if text:
        print()
        print(text)
    return 0


def command_runs_list(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    directories = run_directories(root)
    if not directories:
        print("No runs found")
        return 0
    for directory in directories:
        suffix = " PINNED" if is_pinned(directory) else ""
        print(f"{directory.name}{suffix}")
    return 0


def command_runs_pin(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    directory = run_dir(root, args.run_id)
    if not directory.exists():
        raise SystemExit(f"run not found: {args.run_id}")
    (directory / PINNED_FILE).write_text(f"pinned_at: {now()}\n", encoding="utf-8")
    print(f"Pinned {args.run_id}")
    return 0


def command_runs_unpin(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    marker = run_dir(root, args.run_id) / PINNED_FILE
    if marker.exists():
        marker.unlink()
    print(f"Unpinned {args.run_id}")
    return 0


def command_runs_summarize(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    run_ids = [args.run_id] if args.run_id else [path.name for path in run_directories(root)]
    for run_id in run_ids:
        summarize_run(root, run_id)
        print(f"Summarized {run_id}")
    return 0


def prune_candidates(root: Path, keep: int) -> list[Path]:
    directories = run_directories(root)
    unpinned = [directory for directory in directories if not is_pinned(directory)]
    keep_set = set(unpinned[-keep:]) if keep > 0 else set()
    return [directory for directory in unpinned if directory not in keep_set]


def command_runs_prune(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    candidates = prune_candidates(root, args.keep)
    if not candidates:
        print("No runs to prune")
        return 0

    for directory in candidates:
        summarize_run(root, directory.name)
        if args.yes:
            shutil.rmtree(directory)
            print(f"Pruned {directory.name}")
        else:
            print(f"Would prune {directory.name}")

    if not args.yes:
        print("Dry run only. Re-run with --yes to delete summarized raw run directories.")
    return 0


def command_multi_agent_init(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    run_id = args.run_id or default_run_id()
    directory = create_multi_agent_artifacts(
        root,
        run_id=run_id,
        goal=args.goal,
        context=args.context,
        constraints=args.constraints,
        files=args.files,
    )
    write_state(root, run_id=run_id, current_stage="multi-agent-plan", next_stage="synthesis", blocker="none")
    print(f"Initialized multi-agent planning at {directory.relative_to(root)}")
    return 0


def command_multi_agent_status(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    run_id = args.run_id or active_run_id_from_state(root)
    if not run_id:
        raise SystemExit("--run-id is required when STATE.md has no active run")
    directory = multi_agent_dir(root, run_id)
    if not directory.exists():
        raise SystemExit(f"multi-agent artifacts not found for run: {run_id}")
    for role in MULTI_AGENT_ROLES:
        path = directory / role["file"]
        status = "ready" if draft_is_ready(path) else "missing"
        print(f"{role['file']}: {status}")
    print(f"synthesis.md: {skeleton_status(directory / 'synthesis.md')}")
    print(f"final-plan.md: {skeleton_status(directory / 'final-plan.md')}")
    return 0


def active_run_id_from_state(root: Path) -> str:
    _, text = find_state(root)
    for line in text.splitlines():
        normalized = line.strip().lstrip("-").strip()
        if normalized.startswith("run_id:"):
            value = normalized.split(":", 1)[1].strip()
            return "" if value == "none" else value
    return ""


def bridge_body(directory: Path, role: dict[str, str]) -> str:
    return "\n".join(
        [
            "Goal:",
            "Draft a role-specific plan for this Mingjie Stack run.",
            "",
            "Context:",
            f"Read `{(directory / 'BRIEF.md').as_posix()}` and write your response into `{(directory / role['file']).as_posix()}` if explicitly allowed by the user. Otherwise reply with the draft content.",
            "",
            "Role:",
            role["role"],
            "",
            "Constraints:",
            "Advisory/read-only by default. Do not edit files unless the user has explicitly assigned ownership.",
            "",
            "Files:",
            f"{(directory / 'BRIEF.md').as_posix()}",
            "",
            "Requested action:",
            "Produce the required draft sections for this role.",
            "",
            "Expected output:",
            "Recommended approach, task breakdown, risks and hard stops, verification plan, what another plan may miss, confidence level.",
            "",
        ]
    )


def command_multi_agent_send_bridge(args: argparse.Namespace) -> int:
    root = Path(args.root).resolve()
    run_id = args.run_id or active_run_id_from_state(root)
    if not run_id:
        raise SystemExit("--run-id is required when STATE.md has no active run")
    directory = multi_agent_dir(root, run_id)
    if not directory.exists():
        raise SystemExit(f"multi-agent artifacts not found for run: {run_id}")

    for role in MULTI_AGENT_ROLES:
        body = bridge_body(directory, role)
        cmd = [
            str(BRIDGE),
            "send",
            "--from",
            args.sender,
            "--to",
            role["recipient"],
            "--subject",
            f"{run_id}: {role['role']} draft",
            "--body",
            body,
            "--file",
            str(directory / "BRIEF.md"),
        ]
        if args.dry_run:
            print(" ".join(cmd))
            continue
        subprocess.run(cmd, cwd=root, check=True)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="mingjie-harness")
    parser.add_argument("--root", default=".", help="Project root (default: current directory)")
    subparsers = parser.add_subparsers(dest="command", required=True)

    init = subparsers.add_parser("init", help="Create docs/mingjie-stack and ignore volatile state")
    init.set_defaults(func=command_init)

    start_run = subparsers.add_parser("start-run", help="Create a run directory and STATE.md")
    start_run.add_argument("--id", default="", help="Run id (default: timestamp)")
    start_run.add_argument("--stage", default="started", help="Initial current stage")
    start_run.add_argument("--next", default="intake", help="Initial next stage")
    start_run.set_defaults(func=command_start_run)

    update_state = subparsers.add_parser("update-state", help="Write docs/mingjie-stack/STATE.md")
    update_state.add_argument("--run-id", default="", help="Run id")
    update_state.add_argument("--stage", required=True, help="Current stage")
    update_state.add_argument("--next", required=True, help="Next stage")
    update_state.add_argument("--blocker", default="none", help="Open blocker, if any")
    update_state.set_defaults(func=command_update_state)

    evidence = subparsers.add_parser("append-evidence", help="Append evidence to a run")
    evidence.add_argument("--run-id", default="", help="Run id (default: timestamp)")
    evidence.add_argument("--title", required=True, help="Evidence title")
    evidence.add_argument("--command", default="", help="Command that produced the evidence")
    evidence.add_argument("--result", required=True, help="Result summary")
    evidence.add_argument("--note", default="", help="Optional note")
    evidence.set_defaults(func=command_append_evidence)

    status = subparsers.add_parser("status", help="Show Harness status")
    status.set_defaults(func=command_status)

    runs = subparsers.add_parser("runs", help="Manage run history")
    runs_subparsers = runs.add_subparsers(dest="runs_command", required=True)

    runs_list = runs_subparsers.add_parser("list", help="List run directories")
    runs_list.set_defaults(func=command_runs_list)

    runs_summarize = runs_subparsers.add_parser("summarize", help="Summarize runs into RUNS_INDEX and monthly archive")
    runs_summarize.add_argument("--run-id", default="", help="Specific run id to summarize")
    runs_summarize.set_defaults(func=command_runs_summarize)

    runs_prune = runs_subparsers.add_parser("prune", help="Summarize and prune old unpinned runs")
    runs_prune.add_argument("--keep", type=int, default=10, help="Number of newest unpinned runs to keep")
    runs_prune.add_argument("--dry-run", action="store_true", help="Preview pruning; default unless --yes is used")
    runs_prune.add_argument("--yes", action="store_true", help="Delete summarized raw run directories")
    runs_prune.set_defaults(func=command_runs_prune)

    runs_pin = runs_subparsers.add_parser("pin", help="Prevent a run from being pruned")
    runs_pin.add_argument("run_id")
    runs_pin.set_defaults(func=command_runs_pin)

    runs_unpin = runs_subparsers.add_parser("unpin", help="Allow a run to be pruned")
    runs_unpin.add_argument("run_id")
    runs_unpin.set_defaults(func=command_runs_unpin)

    multi_agent = subparsers.add_parser("multi-agent", help="Create and manage multi-agent planning artifacts")
    multi_agent_subparsers = multi_agent.add_subparsers(dest="multi_agent_command", required=True)

    multi_agent_init = multi_agent_subparsers.add_parser("init", help="Create brief, role drafts, synthesis, and final plan skeletons")
    multi_agent_init.add_argument("--run-id", default="", help="Run id (default: timestamp)")
    multi_agent_init.add_argument("--goal", required=True)
    multi_agent_init.add_argument("--context", default="")
    multi_agent_init.add_argument("--constraints", default="")
    multi_agent_init.add_argument("--files", default="")
    multi_agent_init.set_defaults(func=command_multi_agent_init)

    multi_agent_status = multi_agent_subparsers.add_parser("status", help="Report draft and skeleton status")
    multi_agent_status.add_argument("--run-id", default="")
    multi_agent_status.set_defaults(func=command_multi_agent_status)

    multi_agent_bridge = multi_agent_subparsers.add_parser("send-bridge", help="Send role draft requests through mingjie-bridge")
    multi_agent_bridge.add_argument("--run-id", default="")
    multi_agent_bridge.add_argument("--sender", default="harness")
    multi_agent_bridge.add_argument("--dry-run", action="store_true")
    multi_agent_bridge.set_defaults(func=command_multi_agent_send_bridge)

    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
