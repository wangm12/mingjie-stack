#!/usr/bin/env python3
"""Cross-platform command hook adapter for Mingjie Stack."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import re
import subprocess
import sys


HARNESS_DIR = Path("docs") / "mingjie-stack"
LEGACY_DIR = Path(".mingjie")
HARNESS = Path(__file__).resolve().parent / "mingjie-harness"
COMPLETION_WORDS = (
    "complete",
    "completed",
    "done",
    "fixed",
    "implemented",
    "已完成",
    "完成了",
    "搞定",
)
DANGEROUS_PATTERNS = [
    (re.compile(r"\bgit\s+reset\s+--hard\b"), "git reset --hard requires explicit Guard approval"),
    (re.compile(r"\bgit\s+clean\s+-(?:f|d|x){2,}\b"), "git clean destructive mode requires explicit Guard approval"),
    (re.compile(r"\bgit\s+push\b.*(?:--force|-f)\b"), "force push requires explicit Guard approval"),
    (re.compile(r"\brm\s+-[A-Za-z]*r[A-Za-z]*f\b|\brm\s+-[A-Za-z]*f[A-Za-z]*r\b"), "rm -rf requires explicit Guard approval"),
    (re.compile(r"\bnpm\s+publish\b"), "package publish requires explicit ship authorization"),
    (re.compile(r"\btwine\s+upload\b"), "package publish requires explicit ship authorization"),
    (re.compile(r"\bterraform\s+apply\b"), "terraform apply requires explicit deployment authorization"),
    (re.compile(r"\bkubectl\s+(?:apply|delete)\b"), "kubectl production-style action requires explicit Guard approval"),
    (re.compile(r"\bvercel\b.*\s--prod\b"), "production deploy requires explicit deploy authorization"),
    (re.compile(r"\bfly\s+deploy\b"), "deploy requires explicit deploy authorization"),
]


def load_payload() -> dict:
    try:
        raw = sys.stdin.read()
        if not raw.strip():
            return {}
        data = json.loads(raw)
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def state_paths(root: Path) -> list[Path]:
    return [
        root / HARNESS_DIR / "STATE.md",
        root / LEGACY_DIR / "STATE.md",
    ]


def read_state(root: Path) -> tuple[Path | None, str]:
    for path in state_paths(root):
        if path.exists():
            return path, path.read_text(encoding="utf-8")
    return None, ""


def parse_state_value(text: str, key: str) -> str:
    for line in text.splitlines():
        normalized = line.strip().lstrip("-").strip()
        if normalized.startswith(f"{key}:"):
            return normalized.split(":", 1)[1].strip()
    return ""


def active_run_id(root: Path) -> str:
    _, text = read_state(root)
    run_id = parse_state_value(text, "run_id")
    return "" if run_id == "none" else run_id


def run_evidence_path(root: Path, run_id: str) -> Path:
    return root / HARNESS_DIR / "runs" / run_id / "EVIDENCE.md"


def has_ok_evidence(root: Path, run_id: str) -> bool:
    if not run_id:
        return False
    evidence = run_evidence_path(root, run_id)
    if not evidence.exists():
        return False
    return "Result: OK" in evidence.read_text(encoding="utf-8")


def tool_name(payload: dict) -> str:
    return str(payload.get("tool_name") or payload.get("tool") or "")


def tool_input(payload: dict) -> dict:
    value = payload.get("tool_input") or payload.get("input") or {}
    return value if isinstance(value, dict) else {}


def tool_command(payload: dict) -> str:
    value = tool_input(payload).get("command") or tool_input(payload).get("cmd") or ""
    return str(value)


def event_name(payload: dict, fallback: str) -> str:
    return str(payload.get("hook_event_name") or payload.get("event") or fallback or "")


def block(message: str) -> int:
    sys.stderr.write(f"Blocked: {message}\n")
    return 2


def guard_text(root: Path) -> str:
    run_id = active_run_id(root)
    candidates = []
    if run_id:
        candidates.append(root / HARNESS_DIR / "runs" / run_id / "GUARD.md")
    candidates.append(root / HARNESS_DIR / "GUARD.md")
    parts = []
    for path in candidates:
        if path.exists():
            parts.append(path.read_text(encoding="utf-8").lower())
    return "\n".join(parts)


def guard_allows(root: Path, action: str) -> bool:
    text = guard_text(root)
    return any(
        marker in text
        for marker in (
            f"{action}: allowed",
            f"{action} allowed",
            f"{action}: authorized",
            f"{action} authorized",
        )
    )


def git_remote_text(root: Path) -> str:
    try:
        result = subprocess.run(
            ["git", "remote", "-v"],
            cwd=root,
            capture_output=True,
            text=True,
            timeout=2,
            check=False,
        )
        return result.stdout.lower()
    except Exception:
        return ""


def is_uber_repo(root: Path) -> bool:
    path_signal = any(part.lower() == "uber" for part in root.resolve().parts)
    remote = git_remote_text(root)
    remote_signal = any(token in remote for token in ("uberinternal", "github.com/uber/", "uber.com"))
    return path_signal or remote_signal


def command_result(payload: dict, event: str) -> str:
    response = payload.get("tool_response") or payload.get("tool_result") or payload.get("response") or {}
    if isinstance(response, dict):
        if response.get("success") is True:
            return "OK"
        if response.get("success") is False or response.get("error"):
            return "FAILED"
    if event == "PostToolUse":
        return "OK"
    if event == "PostToolUseFailure":
        return "FAILED"
    return "observed"


def append_evidence(root: Path, command: str, result: str) -> None:
    run_id = active_run_id(root)
    if not run_id:
        return
    subprocess.run(
        [
            sys.executable,
            str(HARNESS),
            "--root",
            str(root),
            "append-evidence",
            "--run-id",
            run_id,
            "--title",
            "Hook captured tool result",
            "--command",
            command,
            "--result",
            result,
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def handle_context(root: Path) -> int:
    state_path, state = read_state(root)
    if not state_path or not state.strip():
        return 0
    sys.stdout.write("[mingjie-stack] Mingjie Harness state detected. Verify it against the repo before continuing.\n")
    sys.stdout.write(f"State file: {state_path.relative_to(root)}\n\n")
    sys.stdout.write(state.strip() + "\n")
    return 0


def handle_pre_tool(root: Path, payload: dict) -> int:
    command = tool_command(payload)
    if not command:
        return 0

    command_lower = command.lower()
    if is_uber_repo(root) and re.search(r"\b(?:git\s+push|gh\s+pr\s+create|hub\s+pull-request)\b", command_lower):
        return block("Uber repo requires Uber workflow skills. Generic GitHub push/PR is prohibited.")

    if re.search(r"\bgit\s+push\b", command_lower) and not guard_allows(root, "push") and not guard_allows(root, "ship"):
        return block("git push requires explicit ship authorization recorded by Guard.")

    if re.search(r"\b(?:deploy|release)\b", command_lower) and not guard_allows(root, "deploy"):
        return block("deploy/release action requires explicit deploy authorization recorded by Guard.")

    for pattern, reason in DANGEROUS_PATTERNS:
        if pattern.search(command_lower):
            return block(f"{reason}: `{command}`")

    return 0


def handle_post_tool(root: Path, payload: dict, event: str) -> int:
    if tool_name(payload) and tool_name(payload).lower() not in {"bash", "shell"}:
        return 0
    command = tool_command(payload)
    if command:
        append_evidence(root, command, command_result(payload, event))
    return 0


def assistant_response(payload: dict) -> str:
    for key in ("assistant_response", "response", "message", "transcript"):
        value = payload.get(key)
        if isinstance(value, str):
            return value
    return ""


def handle_stop(root: Path, payload: dict) -> int:
    if payload.get("stop_hook_active"):
        return 0
    text = assistant_response(payload).lower()
    if not text or not any(word in text for word in COMPLETION_WORDS):
        return 0
    run_id = active_run_id(root)
    if run_id and not has_ok_evidence(root, run_id):
        return block("No fresh Harness verification evidence found. Run verification or report the work as unverified instead of complete.")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="mingjie-hook")
    parser.add_argument("--platform", choices=("auto", "claude", "codex"), default="auto")
    parser.add_argument("--event", default="", help="Override hook event name")
    parser.add_argument("--root", default=".", help="Project root (default: current directory)")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    payload = load_payload()
    root = Path(args.root).resolve()
    event = event_name(payload, args.event)

    if event in {"SessionStart", "UserPromptSubmit"}:
        return handle_context(root)
    if event in {"PreToolUse", "PermissionRequest"}:
        return handle_pre_tool(root, payload)
    if event in {"PostToolUse", "PostToolUseFailure"}:
        return handle_post_tool(root, payload, event)
    if event == "Stop":
        return handle_stop(root, payload)
    return 0


if __name__ == "__main__":
    sys.exit(main())
