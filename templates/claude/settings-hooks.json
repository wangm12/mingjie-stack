{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /ABSOLUTE/PATH/TO/mingjie-stack/scripts/mingjie-hook --platform claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /ABSOLUTE/PATH/TO/mingjie-stack/scripts/mingjie-hook --platform claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
